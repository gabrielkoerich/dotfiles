{
    "agent": {
        "favorite_models": [],
        "tool_permissions": {
            "default": "allow",
        },
        "use_modifier_to_send": true,
        "default_profile": "write",
    },
    "cursor_blink": false,
    "show_edit_predictions": true,
    "edit_predictions": {
        "provider": "zed",
        "disabled_globs": [".env"],
    },
    "base_keymap": "SublimeText",
    "tab_size": 4,
    "autosave": "on_window_change",
    "theme": "Catppuccin Macchiato (Blur)",
    "ui_font_size": 14,
    "buffer_font_size": 15,
    "ui_font_family": "Hasklig",
    "buffer_font_family": "Hasklig",
    "buffer_font_features": {
        "calt": false,
    },
    "soft_wrap": "editor_width",
    "use_autoclose": false,
    "always_treat_brackets_as_autoclosed": false,
    "vim_mode": true,
    "scroll_beyond_last_line": "off",
    "vertical_scroll_margin": 20,
    "command_aliases": {
        "W": "w",
        "Wq": "wq",
        "Q": "q",
    },
    "scrollbar": {
        "show": "auto",
        "cursors": true,
        "git_diff": true,
        "search_results": true,
    },
    "show_whitespaces": "selection",
    "project_panel": {
        "folder_icons": false,
        "indent_size": 5,
        "dock": "left",
        "git_status": true,
        "auto_reveal_entries": false,
        "auto_fold_dirs": true,
    },
    "toolbar": {
        "breadcrumbs": true,
        "quick_actions": true,
        "selections_menu": false,
    },
    "show_call_status_icon": false,
    "current_line_highlight": "all",
    "collaboration_panel": {
        "button": false,
        "default_width": 0,
    },
    "notification_panel": {
        "button": false,
        "default_width": 0,
    },
    "tabs": {
        "file_icons": true,
        "git_status": true,
    },
    "tab_bar": {
        "show": true,
        "show_nav_history_buttons": false,
    },
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
    "diagnostics": {
        "include_warnings": false,
    },
    "git": {
        "git_gutter": "tracked_files",
        "inline_blame": {
            "enabled": true,
        },
    },
    "indent_guides": {
        "enabled": true,
        "line_width": 1,
        "background_coloring": "disabled",
    },
    "preview_tabs": {
        "enabled": true,
        "enable_preview_from_file_finder": true,
        "enable_keep_preview_on_code_navigation": false,
    },
    "file_types": {
        "Shell Script": [
            "sh",
            "bash",
            "zsh",
            "fish",
            "conf",
            "cfg",
            "config",
            "*rc",
            "applescript",
            "Brewfile",
        ],
        "Beancount": ["bean"],
        "Just": ["Justfile"],
        "C": ["pine"],
        "JSONC": ["json.bak", "json.bkp"],
    },

    "languages": {
        "YAML": {
            "format_on_save": "off",
            "tab_size": 2,
        },
        "Beancount": {
            "format_on_save": "off",
            "tab_size": 2,
        },
        "Just": {
            "tab_size": 2,
        },
        "Plain Text": {
            "show_edit_predictions": false,
        },
        "Markdown": {
            "soft_wrap": "preferred_line_length",
            "remove_trailing_whitespace_on_save": false,
        },
    },
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
            },
            "enable_lsp_tasks": true,
        },
    },
    "jupyter": {
        "kernel_selections": {
            "python": "python3",
            "javascript": "deno",
            "typescript": "deno",
            // "r": "ark"
        },
    },
}
